# ─── App ─────────────────────────────────────────────────────────────────────
APP_NAME="Yakero Ecommerce API"
DEBUG=false
TESTING=false
API_BASE_URL=https://api.yakero.cl

# ─── Base de datos ────────────────────────────────────────────────────────────
# Driver: asyncmy (MySQL async)
DATABASE_URL=mysql+asyncmy://yakero_user:yakero_pass@localhost:3306/yakero_ecommerce

# ─── JWT ─────────────────────────────────────────────────────────────────────
# Generar con: openssl rand -hex 32
JWT_SECRET=CAMBIA_ESTO_EN_PRODUCCION_CON_OPENSSL_RAND_HEX_32
JWT_EXPIRE_MINUTES=1440

# ─── MercadoPago ─────────────────────────────────────────────────────────────
# Obtener en: https://www.mercadopago.cl/developers/panel
MP_ACCESS_TOKEN=APP_USR-...
MP_WEBHOOK_SECRET=tu_webhook_secret_de_mp

# URLs de retorno después del pago (deben coincidir con las configuradas en MP)
MP_BACK_URL_SUCCESS=https://yakero.cl/checkout/success
MP_BACK_URL_FAILURE=https://yakero.cl/checkout/failure
MP_BACK_URL_PENDING=https://yakero.cl/checkout/pending

# ─── Ubicación del local (para cálculo de delivery por km) ───────────────────
STORE_LAT=-33.4094
STORE_LON=-70.5799

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Lista separada por comas
ALLOWED_ORIGINS=http://localhost:5173,https://yakero.cl
