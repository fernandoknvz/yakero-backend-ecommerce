# App
APP_NAME="Yakero Ecommerce API"
ENVIRONMENT=development
DEBUG=true
TESTING=false
API_BASE_URL=http://localhost:8000
API_V1_PREFIX=/api/v1

# Database
# Local Docker exposes MySQL on host port 3310.
DATABASE_URL=mysql+asyncmy://yakero_user:yakero_pass@localhost:3310/yakero_ecommerce

# JWT
# Generate a strong value with: openssl rand -hex 32
JWT_SECRET=CAMBIA_ESTO_EN_PRODUCCION_CON_OPENSSL_RAND_HEX_32
JWT_EXPIRE_MINUTES=1440

# MercadoPago
MP_ACCESS_TOKEN=
MP_WEBHOOK_SECRET=
MP_BACK_URL_SUCCESS=http://localhost:5173/checkout/success
MP_BACK_URL_FAILURE=http://localhost:5173/checkout/failure
MP_BACK_URL_PENDING=http://localhost:5173/checkout/pending

# Store location for delivery fee calculation
STORE_LAT=-33.4094
STORE_LON=-70.5799

# CORS
# Comma-separated list. The app also accepts JSON array syntax.
ALLOWED_ORIGINS=http://localhost:5173,https://yakero.cl
